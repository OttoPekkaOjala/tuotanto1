<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="tuotanto1.Views.AsiakasPage"
             Title="Asiakkaat">

    <VerticalStackLayout Padding="20" Spacing="15">

        <Label Text="Asiakashallinta" FontSize="26" />

        <CollectionView ItemsSource="{Binding Asiakkaat}">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame BackgroundColor="#252525"
                           CornerRadius="8"
                           Padding="10"
                           Margin="0,5">
                        <Label Text="{Binding Nimi}" FontSize="18" />
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

    </VerticalStackLayout>

</ContentPage>
