<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:tuotanto1.ViewModels"
             x:Class="tuotanto1.Views.AsiakasPage">

    <ContentPage.BindingContext>
        <vm:AsiakasViewModels />
    </ContentPage.BindingContext>

    <VerticalStackLayout Padding="20">

        <Label Text="Asiakashallinta"
               FontSize="24"
               HorizontalOptions="Center" />

        <ListView ItemsSource="{Binding Asiakkaat}">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <TextCell Text="{Binding Etunimi}"
                              Detail="{Binding Sukunimi}" />
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

    </VerticalStackLayout>

    </ContentPage>