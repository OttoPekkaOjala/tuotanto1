<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:tuotanto1.ViewModels"
             x:Class="tuotanto1.Views.MokkiPage">

    <ContentPage.BindingContext>
        <vm:MokkiViewModel />
    </ContentPage.BindingContext>

    <VerticalStackLayout Padding="20">

        <Label Text="Mökkien hallinta"
               FontSize="24"
               HorizontalOptions="Center" />

        <ListView ItemsSource="{Binding Mokit}">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <TextCell Text="{Binding Mokkinimi}"
                              Detail="{Binding Katuosoite}" />
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

    </VerticalStackLayout>

</ContentPage>