<?xml version = "1.0" encoding = "UTF-8" ?>
<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:tuotanto1"
             x:Class="tuotanto1.App">
    <Application.Resources>
        <ResourceDictionary>

            <!-- Värit -->
            <Color x:Key="BackgroundDark">#1E1E1E</Color>
            <Color x:Key="PanelDark">#252525</Color>
            <Color x:Key="ButtonDark">#333333</Color>
            <Color x:Key="ButtonDarkPressed">#444444</Color>
            <Color x:Key="TextLight">White</Color>

            <!-- Sivun taustat -->
            <Style TargetType="ContentPage">
                <Setter Property="BackgroundColor" Value="{StaticResource BackgroundDark}" />
            </Style>

            <!-- Yleinen nappityyli -->
            <Style TargetType="Button">
                <Setter Property="BackgroundColor" Value="{StaticResource ButtonDark}" />
                <Setter Property="TextColor" Value="{StaticResource TextLight}" />
                <Setter Property="CornerRadius" Value="6" />
                <Setter Property="FontSize" Value="15" />
                <Setter Property="HeightRequest" Value="40" />
                <Setter Property="Padding" Value="10,5" />
                <Setter Property="VisualStateManager.VisualStateGroups">
                    <VisualStateGroupList>
                        <VisualStateGroup x:Name="CommonStates">
                            <VisualState x:Name="Normal">
                                <VisualState.Setters>
                                    <Setter Property="BackgroundColor" Value="{StaticResource ButtonDark}" />
                                </VisualState.Setters>
                            </VisualState>
                            <VisualState x:Name="Pressed">
                                <VisualState.Setters>
                                    <Setter Property="BackgroundColor" Value="{StaticResource ButtonDarkPressed}" />
                                </VisualState.Setters>
                            </VisualState>
                        </VisualStateGroup>
                    </VisualStateGroupList>
                </Setter>
            </Style>

            <!-- Otsikot -->
            <Style TargetType="Label">
                <Setter Property="TextColor" Value="{StaticResource TextLight}" />
            </Style>

        </ResourceDictionary>
    </Application.Resources>

</Application>
